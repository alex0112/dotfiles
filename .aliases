function path() { 
    ## Print a path of a file relative to ~
    ## e.g. `path baz.txt` => "~/subdir/foo/bar/baz.txt"
    
    local relpath=$(echo ${PWD/#$HOME//~} | sed 's/^\///')
    echo -n "$relpath/$1"
}

# testdiff() { ## for CS4400 assignment 4, the shell
#    delta <(make "test$1" 2>&1) <(make "rtest$1" 2>&1);
# }

# Just the diff lines
textdiff() { diff -u <(make "test$1" 2>&1) <(make "rtest$1" 2>&1); }

# Enhanced testdiff that shows visual AND copies text diff
testdiff() { 
    local test="$1"
    diff -u <(make "test$test" 2>&1) <(make "rtest$test" 2>&1) | xclip
    delta <(make "test$test" 2>&1) <(make "rtest$test" 2>&1)
    echo "Diff copied to clipboard!"
}

## Sanity checks on basic secrets/env files. NOT comprehensive, use common sense.
function ensure_no_priv_keys() {
    PRIVATE_KEYS=$(rg -l 'PRIVATE KEY' --glob '!node_modules' --glob '!*.md')

    if [ -n "$PRIVATE_KEYS" ]; then
        printf "ERR: The following files may contain private keys!\n\n$PRIVATE_KEYS\n\n";
        return 1;
    else
        return 0;
    fi
}

function ensure_no_dotenv() {
    ENV_FILES=$(fd -HI ".*\.env.*"  -E node_modules -E "*example*")

    if [ -n "$ENV_FILES" ]; then
        printf "ERR: Found the following env files!\n\n$ENV_FILES\n\n";
        return 1;
    else
        return 0;
    fi
}

function ensure_home_subdir() {
    REAL_PWD=$(realpath "$PWD") ## realpath will follow symlinks

    case $REAL_PWD in
        "$HOME"/*)
            return 0;
            ;;
        *)
            return 1;
    esac
}

## stretch goal for this one: check if JWTs are active(?) Mebbe
# function ensure_no_jwt() { } ## TODO WRITEME

# Claude Sandboxing:
function claude() {
    if ! ensure_home_subdir; then
        echo "claude must only be run in subdirectories of the home directory! (e.g. $HOME/*) Aborting...";
        return 1;
    elif ! ensure_no_dotenv; then
        echo "Refusing to run claude in directories with .env files or other similar secret files. Aborting...";
        return 1;
    elif ! ensure_no_priv_keys; then
        echo "Refusing to run claude where private keys may be exposed to the agent. Aborting...";
        return 1;
    else
        export SANDBOX_REPO=~/ADVANSTAFF/src/claude-sandbox ## or wherever you've cloned the sandbox project
        export MOUNT_PT=$(basename $PWD) ## this is the directory name that gets mounted into the sandbox container
        export CURR_DIR=$PWD
        echo "Invoking claude in a reasonably secure sandbox..."
        just --justfile $SANDBOX_REPO/Justfile agent

        return 0;
    fi
}

