alias gap='git add -p'
alias gc='git commit'
alias gco='git checkout'
alias gd='git diff'
alias gcm='git commit -m'
alias gam='git commit -am'
alias gcam='gam'
alias gp='echo "git push" && git push'
alias grem='git remote get-url --all origin'
alias rem='grem'
alias unstage='echo "git restore --staged" && git restore --staged'
alias restore='unstage'
alias gu='unstage'
alias gr='unstage'
alias gb='git checkout -b'
alias gcob='git checkout -b'

function br() {
    BRANCH=$(git br | fzf);
    git co $BRANCH
}

function up() {
    BRANCH=`git branch | rg '\*' | sed 's/\*//' | tr -d [:space:]`

    if [ -n "$BRANCH" ]; then
        COMMAND="git push --set-upstream origin $BRANCH"
        echo $COMMAND && eval $COMMAND
    else
        echo "Unable to parse branch name, are you in a git repository? Exit status: $? \$BRANCH: '$BRANCH'"
    fi
}

